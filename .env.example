# KrishiAI Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=5001
NODE_ENV=development

# ============================================================
# OPENWEATHERMAP API (FREE TIER)
# Get your free API key at: https://openweathermap.org/api
# Free tier: 1000 calls/day — more than enough for development
# Without API key, the app uses realistic city-based fallback data
# ============================================================
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# ============================================================
# FRONTEND URL (for CORS configuration)
# ============================================================
FRONTEND_URL=http://localhost:3000

# ============================================================
# DATABASE (Optional - for future PostgreSQL integration)
# ============================================================
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=krishiai
# DB_USER=krishiai_user
# DB_PASSWORD=your_secure_password
